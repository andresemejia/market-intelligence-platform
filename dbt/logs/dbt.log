        cast(high  as double)       as high_price,
        cast(low   as double)       as low_price,
        cast(close as double)       as close_price,

        -- Volume
        cast(volume as bigint)      as volume,

        -- Metadata
        ingestion_date,
        silver_processed_date,
        source

    from source

)

select * from renamed
  );

